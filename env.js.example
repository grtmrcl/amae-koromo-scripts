// env.js のテンプレート
// このファイルをコピーして env.js として使用してください
// Docker環境では .env ファイルと docker-compose.yml を使用します

module.exports = {
  // CouchDB接続情報
  COUCHDB_USER: process.env.COUCHDB_USER || "admin",
  COUCHDB_PASSWORD: process.env.COUCHDB_PASSWORD || "password",
  COUCHDB_PROTO: process.env.COUCHDB_PROTO || "http",
  COUCHDB_SERVER: process.env.COUCHDB_SERVER || "couchdb:5984",
  COUCHDB_URL: process.env.COUCHDB_URL || "http://admin:password@couchdb:5984/majsoul",

  // Redisの接続情報
  REDIS_HOST: process.env.REDIS_HOST || "redis",
  REDIS_PASSWORD: process.env.REDIS_PASSWORD || undefined,

  // プレイヤーサーバー (モード番号 → CouchDB URL のマッピング)
  // ランク戦モードID: 9=金東, 12=玉/王東, 16=王座, 8=金東3, 11=玉東3, 15=王座東3
  //                 22=三金, 24=三玉/王東, 26=三王座, 21=三金東, 23=三玉東, 25=三王座東
  // 友人戦モードID (人工ID): 1=4人標準, 2=4人特殊, 3=3人
  PLAYER_SERVERS: process.env.PLAYER_SERVERS
    ? JSON.parse(process.env.PLAYER_SERVERS)
    : {
        9:  process.env.COUCHDB_URL || "http://admin:password@couchdb:5984",
        12: process.env.COUCHDB_URL || "http://admin:password@couchdb:5984",
        16: process.env.COUCHDB_URL || "http://admin:password@couchdb:5984",
        8:  process.env.COUCHDB_URL || "http://admin:password@couchdb:5984",
        11: process.env.COUCHDB_URL || "http://admin:password@couchdb:5984",
        15: process.env.COUCHDB_URL || "http://admin:password@couchdb:5984",
        22: process.env.COUCHDB_URL || "http://admin:password@couchdb:5984",
        24: process.env.COUCHDB_URL || "http://admin:password@couchdb:5984",
        26: process.env.COUCHDB_URL || "http://admin:password@couchdb:5984",
        21: process.env.COUCHDB_URL || "http://admin:password@couchdb:5984",
        23: process.env.COUCHDB_URL || "http://admin:password@couchdb:5984",
        25: process.env.COUCHDB_URL || "http://admin:password@couchdb:5984",
        1:  process.env.COUCHDB_URL || "http://admin:password@couchdb:5984",
        2:  process.env.COUCHDB_URL || "http://admin:password@couchdb:5984",
        3:  process.env.COUCHDB_URL || "http://admin:password@couchdb:5984",
      },

  // 雀魂接続情報
  URL_BASE: process.env.URL_BASE || "",
  ACCESS_TOKEN: process.env.ACCESS_TOKEN || "",
  PREFERRED_SERVER: process.env.PREFERRED_SERVER || "",
  OAUTH_TYPE: process.env.OAUTH_TYPE ? parseInt(process.env.OAUTH_TYPE) : 0,
};
