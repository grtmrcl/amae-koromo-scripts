// env.js のテンプレート
// このファイルをコピーして env.js として使用してください
// Docker環境では .env ファイルと docker-compose.yml を使用します

module.exports = {
  // CouchDB接続情報
  COUCHDB_USER: process.env.COUCHDB_USER || "admin",
  COUCHDB_PASSWORD: process.env.COUCHDB_PASSWORD || "password",
  COUCHDB_PROTO: process.env.COUCHDB_PROTO || "http",
  COUCHDB_SERVER: process.env.COUCHDB_SERVER || "couchdb:5984",
  COUCHDB_URL: process.env.COUCHDB_URL || "http://admin:password@couchdb:5984/majsoul",

  // Redisの接続情報
  REDIS_HOST: process.env.REDIS_HOST || "redis",
  REDIS_PASSWORD: process.env.REDIS_PASSWORD || undefined,

  // プレイヤーサーバー (モード番号 → CouchDB URL のマッピング)
  PLAYER_SERVERS: process.env.PLAYER_SERVERS
    ? JSON.parse(process.env.PLAYER_SERVERS)
    : {
        4: process.env.COUCHDB_URL || "http://admin:password@couchdb:5984",
        3: process.env.COUCHDB_URL || "http://admin:password@couchdb:5984",
      },

  // 雀魂接続情報
  URL_BASE: process.env.URL_BASE || "",
  ACCESS_TOKEN: process.env.ACCESS_TOKEN || "",
  PREFERRED_SERVER: process.env.PREFERRED_SERVER || "",
  OAUTH_TYPE: process.env.OAUTH_TYPE ? parseInt(process.env.OAUTH_TYPE) : 0,
};
